                        },
                        {
                            "name": "Authorization",
                            "value": "Bearer REDACTED_SUPABASE_SERVICE_KEY"
                        },
                        {
                            "name": "Content-Type",
                            "value": "application/json"
                        },
                        {
                            "name": "Prefer",
                            "value": "return=minimal"
                        }
                    ]
                },
                "sendBody": true,
                "contentType": "raw",
                "rawContentType": "application/json",
                "body": "={{ JSON.stringify({ next_call_scheduled_at: $json.next_call_scheduled_at, status: $json.status, follow_up_reason: $json.follow_up_reason }) }}",
                "options": {}
            },
            "id": "http-update-lead",
            "name": "Update Lead Schedule",
            "type": "n8n-nodes-base.httpRequest",
            "typeVersion": 4.2,
            "position": [
                1344,
                200
            ],
            "continueOnFail": true
        },
        {
            "parameters": {
                "jsCode": "// Update campaign metrics: count total_leads, leads_called, leads_connected, leads_converted\n// We aggregate by looking at lead data from the input items\nconst items = $input.all();\nconst campaignData = $('Should Process?').first().json;\nconst campaignId = campaignData.campaignId;\n\n// Just return the campaign ID - the metrics update will query Supabase directly\nreturn [{ json: { campaignId } }];"
            },
