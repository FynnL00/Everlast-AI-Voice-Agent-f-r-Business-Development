            "id": "cron-trigger",
            "name": "Daily 06:00 Trigger",
            "type": "n8n-nodes-base.scheduleTrigger",
            "typeVersion": 1.2,
            "position": [
                0,
                300
            ]
        },
        {
            "parameters": {
                "url": "https://ltarsnseyhtfbsxjrhdu.supabase.co/rest/v1/campaigns?status=eq.active&select=id,name,cadence_config,calling_window_start,calling_window_end,calling_timezone,calling_days",
                "sendHeaders": true,
                "headerParameters": {
                    "parameters": [
                        {
                            "name": "apikey",
                            "value": "REDACTED_SUPABASE_SERVICE_KEY"
                        },
                        {
                            "name": "Authorization",
                            "value": "Bearer REDACTED_SUPABASE_SERVICE_KEY"
                        }
                    ]
                },
                "options": {}
            },
            "id": "http-fetch-campaigns",
            "name": "Fetch Active Campaigns",
            "type": "n8n-nodes-base.httpRequest",
            "typeVersion": 4.2,
            "position": [
                224,
                300
            ]
        },
        {
            "parameters": {
                "jsCode": "// Process campaigns and fetch unscheduled leads for each\nconst campaigns = $input.all().map(item => item.json);\nconst campaignList = Array.isArray(campaigns[0]) ? campaigns[0] : (campaigns[0] && campaigns[0].id ? campaigns : []);\n\nif (campaignList.length === 0) {\n  return [{ json: { skip: true, message: 'Keine aktiven Kampagnen gefunden' } }];\n}\n\nconst results = [];\nfor (const campaign of campaignList) {\n  if (!campaign.id) continue;\n  const cadence = campaign.cadence_config || { max_attempts: 5 };\n  results.push({\n    json: {\n      campaignId: campaign.id,\n      campaignName: campaign.name || 'Unbenannt',\n      maxAttempts: cadence.max_attempts || 5,\n      windowStart: campaign.calling_window_start || '09:00',\n      windowEnd: campaign.calling_window_end || '18:00',\n      callingDays: campaign.calling_days || [1,2,3,4,5],\n      timezone: campaign.calling_timezone || 'Europe/Berlin'\n    }\n  });\n}\n\nreturn results.length > 0 ? results : [{ json: { skip: true } }];"
            },
            "id": "code-process-campaigns",
            "name": "Process Campaigns",
            "type": "n8n-nodes-base.code",
            "typeVersion": 2,
            "position": [
                448,
                300
            ]
        },
        {
            "parameters": {
                "conditions": {
                    "options": {
                        "version": 2,
                        "leftValue": "",
                        "caseSensitive": true,
                        "typeValidation": "strict"
                    },
                    "conditions": [
                        {
                            "id": "c1",
                            "leftValue": "={{ $json.skip }}",
                            "rightValue": true,
                            "operator": {
                                "type": "boolean",
                                "operation": "notEquals"
                            }
                        }
                    ],
                    "combinator": "and"
                },
                "options": {}
            },
            "id": "if-should-process",
            "name": "Should Process?",
            "type": "n8n-nodes-base.if",
            "typeVersion": 2.2,
            "position": [
                672,
                300
            ]
        },
        {
            "parameters": {
                "url": "={{ 'https://ltarsnseyhtfbsxjrhdu.supabase.co/rest/v1/leads?campaign_id=eq.' + $json.campaignId + '&status=in.(queued,attempting,callback_scheduled)&next_call_scheduled_at=is.null&is_dnc=eq.false&call_attempts=lt.' + $json.maxAttempts + '&select=id,phone,call_attempts,caller_name,company&limit=200' }}",
                "sendHeaders": true,
                "headerParameters": {
                    "parameters": [
                        {
                            "name": "apikey",
                            "value": "REDACTED_SUPABASE_SERVICE_KEY"
                        },
                        {
                            "name": "Authorization",
                            "value": "Bearer REDACTED_SUPABASE_SERVICE_KEY"
                        }
                    ]
                },
                "options": {}
            },
            "id": "http-fetch-leads",
            "name": "Fetch Unscheduled Leads",
            "type": "n8n-nodes-base.httpRequest",
            "typeVersion": 4.2,
            "position": [
                896,
                200
            ]
        },
        {
            "parameters": {
                "jsCode": "// Schedule leads: assign next_call_scheduled_at within the campaign calling window\nconst campaignData = $('Should Process?').first().json;\nconst leads = $input.all().map(item => item.json);\nconst leadList = Array.isArray(leads[0]) ? leads[0] : leads;\n\nif (!leadList || leadList.length === 0 || !leadList[0] || !leadList[0].id) {\n  return [{ json: { count: 0, campaignId: campaignData.campaignId, message: 'Keine unplaned Leads' } }];\n}\n\nconst windowStart = campaignData.windowStart || '09:00';\nconst windowEnd = campaignData.windowEnd || '18:00';\nconst [startH, startM] = windowStart.split(':').map(Number);\nconst [endH, endM] = windowEnd.split(':').map(Number);\nconst startMinutes = startH * 60 + startM;\nconst endMinutes = endH * 60 + endM;\nconst windowMinutes = endMinutes - startMinutes;\n\nconst now = new Date();\nconst today = new Date(now);\ntoday.setHours(0, 0, 0, 0);\n\n// Emit individual items for each lead update\nconst results = leadList.map((lead, i) => {\n  const offset = Math.floor(startMinutes + (windowMinutes * i / Math.max(leadList.length, 1)));\n  const jitter = Math.floor(Math.random() * 10);\n  const scheduleTime = new Date(today);\n  scheduleTime.setHours(Math.floor((offset + jitter) / 60), (offset + jitter) % 60, Math.floor(Math.random() * 60), 0);\n  \n  if (scheduleTime < now) {\n    scheduleTime.setDate(scheduleTime.getDate() + 1);\n  }\n  \n  return {\n    json: {\n      leadId: lead.id,\n      next_call_scheduled_at: scheduleTime.toISOString(),\n      status: 'attempting',\n      follow_up_reason: 'Initiale Kampagnen-Planung',\n      campaignId: campaignData.campaignId\n    }\n  };\n});\n\nreturn results;"
            },
            "id": "code-schedule-leads",
            "name": "Schedule Leads",
            "type": "n8n-nodes-base.code",
            "typeVersion": 2,
            "position": [
                1120,
                200
            ]
        },
        {
            "parameters": {
                "method": "PATCH",
                "url": "={{ 'https://ltarsnseyhtfbsxjrhdu.supabase.co/rest/v1/leads?id=eq.' + $json.leadId }}",
                "sendHeaders": true,
                "headerParameters": {
                    "parameters": [
                        {
                            "name": "apikey",
